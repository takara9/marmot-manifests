k8s_apiserver       =   "10.10.0.220"
k8s_metrics_server  =   "v0.8.1"

containerd_version  =   "2.3.1"
runc_version        =   "v1.4.3"
cni_plugins         =   "v1.6.0"
crictl_version      =   "v1.36.0"


helm_version        =   "v4.2.1"
flannel_version     =   "v0.12.0"
calico_version      =   "v3.29.3"
iface_pri           =   "enp2s0"
cpu_arch            =   "amd64"

